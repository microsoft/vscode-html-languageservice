{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Attach",
			"type": "node",
			"request": "attach",
			"port": 6004,
			"sourceMaps": true,
			"outFiles": ["${workspaceRoot}/lib/umd/**"]
		},
		{
			"name": "Unit Tests",
			"type": "node",
			"request": "launch",
			"runtimeArgs": [
				"--enable-source-maps",
				"--test"
			],
			"args": [
				"./lib/umd/test/*.js"
			],
			"cwd": "${workspaceRoot}",
			"sourceMaps": true,
			"outFiles": ["${workspaceRoot}/lib/umd/**"],
			"preLaunchTask": "npm: compile"
		}
	]
}